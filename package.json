{
  "name": "latex2mathml",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder --win portable",
    "electron:build:nsis": "vite build && electron-builder --win nsis"
  },
  "dependencies": {
    "mathml2omml": "^0.5.0",
    "temml": "^0.11.4",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "vite": "^6.3.2"
  },
  "build": {
    "appId": "com.latex2mathml.app",
    "productName": "LaTeX2MathML",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "LaTeX2MathML.exe"
    },
    "compression": "maximum"
  }
}
